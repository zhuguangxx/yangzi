{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "./dist",
  "nodeVersion": "20.18.0",
  "rewrites": [
    {
      "source": "/api/*",
      "destination": "/api/:splat"
    }
  ],
  "headers": [
    {
      "source": "/assets/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "cloudFunctions": {
    "nodejs": {
      "includeFiles": [
        "supabase.js",
        "utils/**"
      ],
      "externalNodeModules": [
        "@supabase/supabase-js",
        "multer",
        "exifr"
      ],
      "maxDuration": 60
    }
  }
}
