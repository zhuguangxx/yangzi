{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "./dist",
  "nodeVersion": "20.18.0",
  "rewrites": [
    {
      "source": "/api/*",
      "destination": "/api/:splat",
      "has": [
        {
          "type": "host",
          "value": "*"
        }
      ]
    }
  ],
  "cloudFunctions": {
    "nodejs": {
      "includeFiles": [
        "supabase.js",
        "utils/**"
      ],
      "externalNodeModules": [
        "@supabase/supabase-js",
        "multer",
        "exifr"
      ],
      "maxDuration": 60
    }
  }
}
